{
  "name": "slidewell",
  "version": "0.3.0",
  "description": "SlideWell — desktop slide & image archive (the well) for the presentation ecosystem",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && electron-vite build",
    "icon": "node build/make-icon.mjs",
    "preview": "electron-vite preview",
    "start": "electron .",
    "pack": "electron-vite build && electron-builder --mac --dir",
    "dist:mac": "tsc --noEmit && electron-vite build && electron-builder --mac",
    "test": "vitest run",
    "test:smoke": "electron-vite build && node e2e/smoke.mjs",
    "test:triage": "electron-vite build && node e2e/triage.mjs"
  },
  "build": {
    "appId": "net.dominiklukes.slidewell",
    "productName": "SlideWell",
    "asar": false,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "identity": null
    },
    "dmg": {
      "title": "SlideWell ${version}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "techczech",
        "repo": "slidewell",
        "releaseType": "draft"
      }
    ]
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.18.6",
    "@codemirror/commands": "^6.7.1",
    "@codemirror/lang-markdown": "^6.3.1",
    "@codemirror/language": "^6.10.6",
    "@codemirror/language-data": "^6.5.1",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.36.1",
    "@electron/rebuild": "^4.0.4",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "42.4.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "5.0.0",
    "playwright": "^1.60.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "vitest": "^3.2.6"
  },
  "dependencies": {
    "aws4fetch": "^1.0.20",
    "sharp": "^0.34.5"
  }
}
